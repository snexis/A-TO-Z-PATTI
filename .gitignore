# Dependency directories (ভবিষ্যতে npm ব্যবহার করলে)
node_modules/
jspm_packages/
web_modules/

# IDE and Editor files (এডিটর বা কোড এডিটরের নিজস্ব ফাইল)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Operating System files (অপারেটিং সিস্টেমের আবর্জনা ফাইল)
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# Logs (লগ ফাইল)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local Firebase files (ফায়ারবেসের নিজস্ব লোকাল কনফিগ)
.firebase/
*-debug.log
firebase-debug.log

# Environment variables & Secret files (ভবিষ্যতে কোনো সিক্রেট কি রাখলে)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
